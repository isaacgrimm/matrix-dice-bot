# .dockerignore
# Ignore Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore environment files
.env
.env.example

# Ignore logs
bot.log

# Ignore IDE and editor files
.idea/
.vscode/
*.swp
*.swo

# Ignore build artifacts
*.egg-info/
dist/
build/

# Ignore documentation builds
docs/_build/

# Ignore version control
.git/
.gitignore

# Ignore OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
