# Matrix Dice Bot Environment Configuration
# Copy this file to .env and fill in your actual values

# Matrix Server Configuration
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USERNAME=@yourbot:matrix.org
MATRIX_PASSWORD=your_password_here

# Room Configuration (use room ID or alias)
MATRIX_ROOM=!roomid:matrix.org

# Bot Configuration
BOT_DEVICE_NAME=Matrix Dice Bot
BOT_COMMAND_PREFIX=!

# Dice Configuration
MAX_DICE_COUNT=10
MAX_DICE_SIDES=1000

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=bot.log

# Optional: Access Token (if using token auth instead of password)
# MATRIX_ACCESS_TOKEN=your_access_token_here
